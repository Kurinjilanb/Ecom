# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=your-secret-key-here
DEBUG=False
ENVIRONMENT=production

# Comma-separated list of allowed hostnames (e.g. myapp.railway.app,myapp.com)
ALLOWED_HOSTS=*

# ── Database ──────────────────────────────────────────────────────────────────
# Railway / Render: set DATABASE_URL (auto-provided by their PostgreSQL plugin)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Local Docker Compose: use individual vars instead
# POSTGRES_DB=ecommerce_db
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# DATABASE_HOST=db
# DATABASE_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
# Railway: auto-provided by Redis plugin
REDIS_URL=redis://localhost:6379

# ── Email (use Gmail App Password, SendGrid, Mailgun, etc.) ──────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Marketplace Support <noreply@yourapp.com>

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── App ───────────────────────────────────────────────────────────────────────
ADMIN_USER_NAME=admin
HOST_WEB_PORT=8000
HOST_REDIS_PORT=6379

# ── OAuth2 ────────────────────────────────────────────────────────────────────
# Create via Django admin after first deploy: /admin/ → OAuth2 → Applications
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=